generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model OtpRequestLog {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  createdAt DateTime @default(now())

  @@map("otp_request_logs")
}

model User {
  id                Int           @id @default(autoincrement())
  firstName         String
  lastName          String
  mobileNumber      String?       @unique
  phone             String?
  email             String        @unique
  password          String
  city              String?
  role              Role          @default(USER)
  isVerified        Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  passwordChangedAt DateTime?
  sessions          UserSession[]
  firmId            Int?
  firm              Firm?         @relation("FirmUsers", fields: [firmId], references: [id])
  administeredFirm  Firm?         @relation("FirmAdmin")

  @@map("users")
}

model UserSession {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                Int
  accessToken           String   @unique
  refreshToken          String   @unique
  idToken               String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  idTokenExpiresAt      DateTime
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model ForgotPasswordOtp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("forgot_password_otps")
}

model DeleteAccountOtp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("delete_account_otps")
}

model Firm {
  id       Int        @id @default(autoincrement())
  firmName String
  email    String     @unique
  phone    String
  address  String?
  city     String?
  state    String?
  country  String?
  pincode  String?
  status   FirmStatus @default(ACTIVE)

  firmAdminId Int    @unique
  firmAdmin   User   @relation("FirmAdmin", fields: [firmAdminId], references: [id], onDelete: Restrict)
  users       User[] @relation("FirmUsers")

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("firms")
}

enum Role {
  SUPER_ADMIN
  FIRM_ADMIN
  USER
  EMPLOYEE
  CLIENT
  ADMIN
}

enum FirmStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}
