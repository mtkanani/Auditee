generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("otps")
}

model OtpRequestLog {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  createdAt DateTime @default(now())

  @@map("otp_request_logs")
}

model User {
  id                Int        @id @default(autoincrement())
  firstName         String
  lastName          String
  mobileNumber      String?    @unique
  phone             String?
  email             String     @unique
  password          String
  city              String?
  designation       String?
  role              Role       @default(USER)
  status            UserStatus @default(ACTIVE)
  profileImage      String?
  joiningDate       DateTime?
  createdBy         Int?
  isVerified        Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?
  passwordChangedAt DateTime?

  firmId           Int?
  firm             Firm?         @relation("FirmUsers", fields: [firmId], references: [id])
  administeredFirm Firm?         @relation("FirmAdmin")
  sessions         UserSession[]

  clientAssignments    ClientAssignment[] @relation("UserClientAssignments")
  createdAssignments   ClientAssignment[] @relation("AssignmentCreatedBy")
  assignedTasks        Task[]             @relation("TaskAssignedUser")
  createdTasks         Task[]             @relation("TaskCreatedByUser")
  timeEntries          TimeEntry[]
  createdAnnouncements Announcement[]     @relation("AnnouncementCreator")
  announcementReads    AnnouncementRead[]
  taskAssignees        TaskAssignee[]
  attendanceRecords    AttendanceRecord[]
  leaveRequests        LeaveRequest[]
  leaveBalances        LeaveBalance[]

  @@map("users")
}

model Client {
  id               Int     @id @default(autoincrement())
  firmId           Int
  clientType       String  @default("INDIVIDUAL")
  clientName       String
  companyName      String?
  email            String  @unique
  phone            String?
  alternatePhone   String?
  password         String?
  gstNumber        String?
  panNumber        String?
  tanNumber        String?
  cinNumber        String?
  businessType     String?
  industryCategory String?
  website          String?

  // Primary Contact Person Details
  contactPersonName        String?
  contactPersonDesignation String?
  contactPersonEmail       String?
  contactPersonPhone       String?

  // Address Details
  address        String?
  city           String?
  state          String?
  country        String?
  pincode        String?
  billingAddress String?

  // Billing Details
  paymentTerms        String? @default("NET_30")
  taxRegistrationType String? @default("REGULAR")
  outstandingBalance  Float   @default(0.0)
  billingNotes        String?

  status    ClientStatus @default(ACTIVE)
  createdBy Int?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  firm            Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  assignments     ClientAssignment[]
  tasks           Task[]
  sessions        UserSession[]
  services        ClientServiceItem[]
  documents       ClientDocument[]
  activityLogs    ClientActivityLog[]
  complianceItems ComplianceItem[]
  convertedLead   Lead?
  invoices        Invoice[]

  @@map("clients")
}

model ClientServiceItem {
  id               Int      @id @default(autoincrement())
  clientId         Int
  serviceName      String
  serviceCategory  String?
  billingFrequency String   @default("MONTHLY")
  feeAmount        Float    @default(0.0)
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_service_items")
}

model ClientDocument {
  id           Int      @id @default(autoincrement())
  clientId     Int
  documentName String
  documentType String?
  fileUrl      String
  fileSize     Int?
  uploadedBy   Int?
  createdAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_documents")
}

model ClientActivityLog {
  id            Int      @id @default(autoincrement())
  clientId      Int
  action        String
  description   String
  performedBy   Int?
  performedName String?
  createdAt     DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_activity_logs")
}

model ClientAssignment {
  id         Int      @id @default(autoincrement())
  clientId   Int
  userId     Int
  assignedBy Int?
  assignedAt DateTime @default(now())

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation("UserClientAssignments", fields: [userId], references: [id], onDelete: Cascade)
  assigner User?  @relation("AssignmentCreatedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([clientId, userId])
  @@map("client_assignments")
}

model Task {
  id            Int           @id @default(autoincrement())
  firmId        Int
  clientId      Int?
  userId        Int?
  title         String
  description   String?
  priority      TaskPriority  @default(MEDIUM)
  status        TaskStatus    @default(PENDING)
  dueDate       DateTime?
  createdByType CreatedByType @default(CLIENT)
  createdBy     Int?
  templateId    Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  firm          Firm             @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client        Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user          User?            @relation("TaskAssignedUser", fields: [userId], references: [id], onDelete: SetNull)
  creator       User?            @relation("TaskCreatedByUser", fields: [createdBy], references: [id], onDelete: SetNull)
  documents     TaskDocument[]
  timeEntries   TimeEntry[]
  assignees     TaskAssignee[]
  subtasks      TaskSubtask[]
  comments      TaskComment[]
  history       TaskHistory[]
  dependencies  TaskDependency[] @relation("TaskSuccessor")
  prerequisites TaskDependency[] @relation("TaskPredecessor")

  @@map("tasks")
}

model TaskAssignee {
  id         Int      @id @default(autoincrement())
  taskId     Int
  userId     Int
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model TaskSubtask {
  id          Int       @id @default(autoincrement())
  taskId      Int
  title       String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy Int?
  createdAt   DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_subtasks")
}

model TaskComment {
  id            Int      @id @default(autoincrement())
  taskId        Int
  userId        Int?
  clientId      Int?
  commenterName String
  commenterRole String   @default("EMPLOYEE")
  comment       String
  fileUrl       String?
  createdAt     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model TaskHistory {
  id            Int      @id @default(autoincrement())
  taskId        Int
  action        String
  details       String
  performedBy   Int?
  performedName String
  createdAt     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_history")
}

model TaskTemplate {
  id              Int          @id @default(autoincrement())
  firmId          Int
  title           String
  category        String       @default("GENERAL")
  priority        TaskPriority @default(MEDIUM)
  description     String?
  defaultSubtasks String?
  createdAt       DateTime     @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("task_templates")
}

model TaskDependency {
  id              Int @id @default(autoincrement())
  taskId          Int
  dependsOnTaskId Int

  task          Task @relation("TaskSuccessor", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskPredecessor", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@map("task_dependencies")
}

model TaskDocument {
  id           Int      @id @default(autoincrement())
  taskId       Int
  fileName     String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  uploadedBy   Int?
  uploadedRole String?
  createdAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_documents")
}

model TimeEntry {
  id          Int      @id @default(autoincrement())
  taskId      Int
  userId      Int
  hours       Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model UserSession {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                Int?
  clientId              Int?
  accessToken           String   @unique
  refreshToken          String   @unique
  idToken               String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  idTokenExpiresAt      DateTime
  createdAt             DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model ForgotPasswordOtp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("forgot_password_otps")
}

model DeleteAccountOtp {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("delete_account_otps")
}

model Firm {
  id       Int        @id @default(autoincrement())
  firmName String
  email    String     @unique
  phone    String
  address  String?
  city     String?
  state    String?
  country  String?
  pincode  String?
  status   FirmStatus @default(ACTIVE)

  firmAdminId       Int                @unique
  firmAdmin         User               @relation("FirmAdmin", fields: [firmAdminId], references: [id], onDelete: Restrict)
  users             User[]             @relation("FirmUsers")
  clients           Client[]
  tasks             Task[]
  announcements     Announcement[]
  taskTemplates     TaskTemplate[]
  complianceItems   ComplianceItem[]
  leads             Lead[]
  invoices          Invoice[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("firms")
}

model ComplianceItem {
  id             Int              @id @default(autoincrement())
  firmId         Int
  clientId       Int?
  title          String
  category       String           @default("GST")
  dueDate        DateTime
  period         String?
  priority       TaskPriority     @default(MEDIUM)
  status         ComplianceStatus @default(UPCOMING)
  penaltyDetails String?
  autoTaskId     Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  firm   Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("compliance_items")
}

enum ComplianceStatus {
  UPCOMING
  IN_PROGRESS
  FILED
  OVERDUE
  EXTENDED
}

model Announcement {
  id        Int            @id @default(autoincrement())
  firmId    Int
  title     String
  content   String
  category  String         @default("GENERAL")
  priority  NoticePriority @default(INFO)
  createdBy Int
  expiresAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  firm    Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  creator User               @relation("AnnouncementCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  reads   AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  id             Int       @id @default(autoincrement())
  announcementId Int
  userId         Int
  readAt         DateTime  @default(now())
  acknowledgedAt DateTime?

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_reads")
}

enum Role {
  SUPER_ADMIN
  FIRM_ADMIN
  USER
  EMPLOYEE
  CLIENT
  ADMIN
}

enum FirmStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETED
  CANCELLED
  REQUESTED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NoticePriority {
  INFO
  WARNING
  URGENT
}

enum CreatedByType {
  FIRM_ADMIN
  USER
  CLIENT
}

model Lead {
  id                 Int       @id @default(autoincrement())
  firmId             Int
  leadName           String
  companyName        String?
  email              String
  phone              String?
  alternatePhone     String?
  businessType       String?
  gstNumber          String?
  panNumber          String?
  interestedServices String?
  estimatedValue     Float     @default(0.0)
  source             String?   @default("DIRECT")
  stage              LeadStage @default(NEW_LEAD)
  nextFollowUp       DateTime?
  notes              String?
  convertedClientId  Int?      @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  firm            Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  convertedClient Client?           @relation(fields: [convertedClientId], references: [id], onDelete: SetNull)
  callLogs        LeadCallLog[]
  meetingNotes    LeadMeetingNote[]
  proposals       LeadProposal[]

  @@map("leads")
}

model LeadCallLog {
  id              Int       @id @default(autoincrement())
  leadId          Int
  callSummary     String
  durationMinutes Int?
  followUpDate    DateTime?
  loggedBy        Int?
  loggedName      String?
  createdAt       DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_call_logs")
}

model LeadMeetingNote {
  id           Int      @id @default(autoincrement())
  leadId       Int
  meetingTitle String
  meetingNotes String
  meetingDate  DateTime @default(now())
  attendees    String?
  loggedBy     Int?
  createdAt    DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_meeting_notes")
}

model LeadProposal {
  id               Int      @id @default(autoincrement())
  leadId           Int
  proposalTitle    String
  proposedFee      Float    @default(0.0)
  billingFrequency String   @default("MONTHLY")
  scopeDescription String?
  fileUrl          String?
  createdAt        DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_proposals")
}

enum LeadStage {
  NEW_LEAD
  DISCUSSION
  PROPOSAL_SENT
  WON
  LOST
}

model Invoice {
  id            Int           @id @default(autoincrement())
  firmId        Int
  clientId      Int
  invoiceNumber String
  invoiceType   InvoiceType   @default(TAX_INVOICE)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  placeOfSupply String?       @default("24-GUJARAT")
  isInterState  Boolean       @default(false)
  subTotal      Float         @default(0.0)
  cgstAmount    Float         @default(0.0)
  sgstAmount    Float         @default(0.0)
  igstAmount    Float         @default(0.0)
  totalAmount   Float         @default(0.0)
  paidAmount    Float         @default(0.0)
  balanceAmount Float         @default(0.0)
  status        InvoiceStatus @default(UNPAID)
  notes         String?
  terms         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  firm     Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments PaymentRecord[]

  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  sacCode     String? @default("998231")
  quantity    Int     @default(1)
  unitPrice   Float   @default(0.0)
  amount      Float   @default(0.0)
  gstRate     Float   @default(18.0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model PaymentRecord {
  id              Int      @id @default(autoincrement())
  invoiceId       Int
  amount          Float
  paymentDate     DateTime @default(now())
  paymentMode     String   @default("BANK_TRANSFER")
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payment_records")
}

enum InvoiceType {
  TAX_INVOICE
  PROFORMA
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model AttendanceRecord {
  id               Int              @id @default(autoincrement())
  firmId           Int
  userId           Int
  date             DateTime
  checkInTime      DateTime         @default(now())
  checkOutTime     DateTime?
  workingHours     Float            @default(0.0)
  status           AttendanceStatus @default(PRESENT)
  checkInLat       Float?
  checkInLng       Float?
  checkInLocation  String?
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutLocation String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance_records")
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  ON_LEAVE
}

model LeaveRequest {
  id           Int                @id @default(autoincrement())
  firmId       Int
  userId       Int
  leaveType    LeaveType          @default(CASUAL_LEAVE)
  startDate    DateTime
  endDate      DateTime
  totalDays    Float              @default(1.0)
  reason       String
  status       LeaveRequestStatus @default(PENDING)
  adminRemarks String?
  reviewedBy   Int?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model LeaveBalance {
  id              Int      @id @default(autoincrement())
  firmId          Int
  userId          Int
  year            Int      @default(2026)
  casualLeave     Float    @default(12.0)
  casualLeaveUsed Float    @default(0.0)
  sickLeave       Float    @default(10.0)
  sickLeaveUsed   Float    @default(0.0)
  earnedLeave     Float    @default(15.0)
  earnedLeaveUsed Float    @default(0.0)
  updatedAt       DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@map("leave_balances")
}

enum LeaveType {
  CASUAL_LEAVE
  SICK_LEAVE
  EARNED_LEAVE
  UNPAID_LEAVE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}
