# Server configuration
PORT=5001
NODE_ENV=development
TZ="Asia/Kolkata"

# Database configuration
# Replace with your PostgreSQL connection URL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:Mitu@8776@localhost:5000/otp_verification_db"

# SMTP (Email) configuration
# For local testing, you can use Ethereal Mail or standard service configuration.
SMTP_HOST=smtp.ethere
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# Token Expiry Configurations
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
ID_TOKEN_EXPIRY_MINUTES=60
