{
  "name": "otp-verification-backend",
  "version": "1.0.0",
  "description": "Production-ready OTP verification backend module using Node.js, Express, PostgreSQL, Prisma, Nodemailer, and Swagger.",
  "main": "src/index.js",
  "scripts": {
    "start": "npx prisma generate && npx prisma db push && node src/index.js",
    "dev": "nodemon src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "nodemailer": "^6.9.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
